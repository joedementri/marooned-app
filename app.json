{
  "expo": {
    "name": "Marooned",
    "slug": "marooned",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "marooned",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0e1428"
    },
    "ios": {
      "bundleIdentifier": "com.marooned.app",
      "supportsTablet": false,
      "infoPlist": {
        "UIRequiresFullScreen": true
      }
    },
    "android": {
      "package": "com.marooned.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0e1428"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "ac029025-d0e4-4a10-95f4-829e697a649d"
      }
    },
    "owner": "joedementri"
  }
}
